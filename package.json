    "@sveltejs/kit": "^2.8.3",
    "@sveltejs/vite-plugin-svelte": "^4.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.1",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.2.7",
