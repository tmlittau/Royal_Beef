# Path to the SQLite database file (used by the app and the migrate script).
# Local dev: a file in the project root. Docker: a path on the mounted volume.
DATABASE_URL=royalbeef.db

# Where downloaded Steam cover art is stored (optional; defaults to data/covers).
# Docker sets this to /app/data/covers so covers persist on the volume.
COVERS_DIR=data/covers

# Where your controller images live (optional; defaults to data/controllers).
# Drop one image per controller you own into this folder — the seed script scans it
# on every boot and adds an inventory entry (quantity 1) for each new image. These are
# your own static assets, so in Docker bind-mount the folder in (see docker-compose.yaml).
CONTROLLERS_DIR=data/controllers
